{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "eqeqeq": "error"
  },
  "ignorePatterns": [
    "zig-out",
    "zig-cache",
    ".zig-cache",
    "node_modules",
    "references",
    "tests/test262"
  ]
}
