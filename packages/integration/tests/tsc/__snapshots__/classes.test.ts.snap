	}
}
// ok
class C extends K {
	m2() {
		let { priv:a } = this;
		// error
let { prot:b } = this;
	}
}
// ok
let k = new K();
let { priv:priv } = k;
// error
let { prot:prot } = k;
// error
let { privateMethod:privateMethod } = k;
// error
let { priv:a, prot:b, privateMethod:pm } = k;
// error
function f({ priv:priv, prot:prot, privateMethod:privateMethod }) {
}
"
`;

