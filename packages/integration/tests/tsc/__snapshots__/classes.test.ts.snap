		// Error
this.b = this.#d;
		//Error
this.b = x;
		this.#d = x;
		let y = this.c;
	}
}
// Property is considered initialized by type any even though value could be undefined
class C11 {
	a;
	#b;
	constructor() {
		this.a = someValue();
		this.#b = someValue();
	}
}
const a = "a";
const b = Symbol();
class C12 {
	[a];
	[b];
	["c"];
	constructor() {
		this[a] = 1;
		this[b] = 1;
		this["c"] = 1;
	}
}
var E = /* @__PURE__ */ ((E) => {E[E["A"]="A"]="A";E[E["B"]="B"]="B";return E;})(E || {});
class C13 {
	[E.A];
