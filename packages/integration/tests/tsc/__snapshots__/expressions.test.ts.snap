a2.a;
// string | number | undefined
a2.b;
// number | undefined
a2 = { a: 10, b: 20 };
a2 = { a: "def" };
a2 = {};
a2 = { a: "def", b: 20 };
// Error
a2 = { a: 1 };
// Error
// Object literals containing spreads are not normalized
let b2 = { ...b1, z: 55 };
let b3 = { ...b2 };
