	var a = () => {
		var arg = arguments[0];
	};
};
// error
function baz() {
	() => {
		var arg = arguments[0];
	};
}
function foo(inputFunc) {
}
foo(() => {
	var arg = arguments[0];
});
// error
function bar() {
	var arg = arguments[0];
}
// no error
() => {
	function foo() {
		var arg = arguments[0];
	}
};
// no error
"
`;

